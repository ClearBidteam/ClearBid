<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ClearBid | Sign Up</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#f7f9fc;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.signup-box{
background:white;
width:420px;
padding:40px;
border-radius:15px;
box-shadow:0 10px 30px rgba(0,0,0,.1);
}

h1{
text-align:center;
margin-bottom:10px;
color:#0d6efd;
}

p{
text-align:center;
margin-bottom:30px;
color:#666;
}

input{
width:100%;
padding:15px;
margin-bottom:15px;
border:1px solid #ddd;
border-radius:8px;
font-size:16px;
}

button{
width:100%;
padding:15px;
background:#0d6efd;
color:white;
border:none;
border-radius:8px;
font-size:16px;
cursor:pointer;
transition:.3s;
}

button:hover{
background:#0956c6;
}

.login-link{
text-align:center;
margin-top:20px;
}

.login-link a{
color:#0d6efd;
text-decoration:none;
font-weight:bold;
}

</style>

</head>

<body>

<div class="signup-box">

<h1>Create Account</h1>

<p>Join ClearBid and start buying & selling today.</p>

<form>

<input type="text" placeholder="Full Name" required>

<input type="email" placeholder="Email Address" required>

<input type="password" placeholder="Password" required>

<input type="password" placeholder="Confirm Password" required>

<button type="submit">Create Account</button>

</form>

<div class="login-link">
Already have an account?
<a href="login.html">Login</a>
</div>

</div>

</body>
</html>
